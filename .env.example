# ---- Flask App Configuration ----
# Secret key for sessions and security (change this in production)
SECRET_KEY=your_secret_key_here

# ---- Email Configuration (Flask-Mail) ----
# Uses Gmail SMTP. Enable 2FA on Gmail, then create an App Password at:
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ---- Contact Details ----
# Where form submissions will be sent
OWNER_EMAIL=your-email@gmail.com
OWNER_WHATSAPP=+920000000000

# ---- Meta WhatsApp API Configuration ----
# Get these tokens from the Meta Developer Dashboard
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_id_here
